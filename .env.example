# ── Discord Bot ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your-bot-token-here
DISCORD_OWNER_IDS=123456789012345678,987654321098765432

# ── Discord OAuth2 (Dashboard, optional) ──────────────────────────────────────
DISCORD_CLIENT_ID=your-client-id
DISCORD_CLIENT_SECRET=your-client-secret
DISCORD_REDIRECT_URI=https://yourdomain.com/callback

# ── Dashboard ──────────────────────────────────────────────────────────────────
DASHBOARD_SECRET=change_this_to_a_random_string

# ── AI API Keys (optional — only needed for the AI cog) ───────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
